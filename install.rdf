<?xml version="1.0" encoding="utf-8"?>
<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">

  <Description about="urn:mozilla:install-manifest">
    <em:id>videospeed-uxp@secondcityosd</em:id>
    <em:version>0.9.1</em:version>
    <em:type>2</em:type>

    <em:name>Video Speed Controller</em:name>
    <em:description>Speed up, slow down, advance and rewind HTML5 audio/video with shortcuts</em:description>
    <em:creator>SecondCityOsD</em:creator>
    <em:homepageURL>https://github.com/SecondCityOsD/videospeed</em:homepageURL>
    <em:updateURL>https://raw.githubusercontent.com/SecondCityOsD/videospeed/main/update.rdf</em:updateURL>
    <em:iconURL>chrome://videospeed/skin/icon48.png</em:iconURL>

    <!-- Pale Moon -->
    <em:targetApplication>
      <Description>
        <em:id>{8de7fcbb-c55c-4fbe-bfc5-fc555c87dbc4}</em:id>
        <em:minVersion>28.0</em:minVersion>
        <em:maxVersion>33.*</em:maxVersion>
      </Description>
    </em:targetApplication>

    <!-- Basilisk -->
    <em:targetApplication>
      <Description>
        <em:id>{ec8030f7-c20a-464f-9b0e-13a3a9e97384}</em:id>
        <em:minVersion>52.0</em:minVersion>
        <em:maxVersion>56.*</em:maxVersion>
      </Description>
    </em:targetApplication>
  </Description>

</RDF>
